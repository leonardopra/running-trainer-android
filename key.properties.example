# key.properties — template for Android release signing.
# Copy this file to key.properties at the repo root (never commit the real file!).
# In CI, these values are injected automatically from GitHub Secrets
# (KEYSTORE_BASE64, KEY_ALIAS, KEY_PASSWORD, STORE_PASSWORD).

storeFile=upload-keystore.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=upload
keyPassword=YOUR_KEY_PASSWORD
